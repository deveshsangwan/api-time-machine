{
  "name": "api-time-machine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "dev:backend": "pnpm --filter @atm/backend dev",
    "dev:mobile": "pnpm --filter @atm/mobile start",
    "dev:dashboard": "pnpm --filter @atm/dashboard dev",
    "smoke": "pnpm --filter @atm/cli smoke",
    "smoke:package": "pnpm --filter @atm/cli smoke:package"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
